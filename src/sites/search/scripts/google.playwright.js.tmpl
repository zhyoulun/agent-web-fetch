const { chromium } = require('@playwright/test');
const fs = require('fs');
const path = require('path');

const query = {{ js .Query }};
const profileDir = {{ js .ProfileDir }};
const channel = {{ js .Channel }};
const maxResults = {{ .MaxResults }};
const timeoutMs = {{ .TimeoutMS }};
const headlessMode = {{ js .HeadlessMode }};
const snapshot = {{ if .Snapshot }}true{{ else }}false{{ end }};
const snapshotStamp = {{ js .SnapshotStamp }};
const projectRoot = {{ js .ProjectRoot }};
const outputJSON = {{ js .OutputPath }};

function writeResult(data) {
  fs.writeFileSync(outputJSON, JSON.stringify(data), 'utf8');
}

function sleep(ms) {
  return new Promise(resolve => setTimeout(resolve, ms));
}

function resultSelectors() {
  return [
    'div#search div#rso h3',
    'div#search div.MjjYud h3',
    'div#search div.g h3',
    'div#search a h3',
    'div#rso a h3',
    'a h3'
  ];
}

function detectHumanVerification(url, content) {
  const lowURL = String(url || '').toLowerCase();
  for (const marker of ['/sorry/', 'recaptcha', 'interstitial']) {
    if (lowURL.includes(marker)) {
      return marker;
    }
  }

  const body = String(content || '').toLowerCase();
  const keywords = [
    'unusual traffic',
    'verify you are human',
    "i'm not a robot",
    'detected unusual traffic',
    '我们的系统检测到您的计算机网络中存在异常流量',
    '请完成以下验证',
    '输入您看到的字符'
  ];
  for (const keyword of keywords) {
    if (body.includes(keyword.toLowerCase())) {
      return keyword;
    }
  }
  return '';
}

function isGoogleHost(hostname) {
  const host = String(hostname || '').trim().toLowerCase();
  return host === 'google.com' || host.endsWith('.google.com');
}

function normalizeGoogleLink(raw) {
  if (!raw) {
    return '';
  }

  let parsed;
  try {
    parsed = new URL(String(raw).trim().replaceAll('&amp;', '&'), 'https://www.google.com');
  } catch {
    return '';
  }

  if (!['http:', 'https:'].includes(parsed.protocol)) {
    return '';
  }

  for (let i = 0; i < 5; i++) {
    const host = parsed.hostname.toLowerCase();
    const pathname = parsed.pathname.toLowerCase();

    if (isGoogleHost(host) && (pathname === '/url' || pathname === '/imgres')) {
      const target = parsed.searchParams.get('q') || parsed.searchParams.get('url') || parsed.searchParams.get('imgurl');
      if (!target) {
        return '';
      }
      try {
        parsed = new URL(target, parsed);
      } catch {
        return '';
      }
      if (!['http:', 'https:'].includes(parsed.protocol)) {
        return '';
      }
      continue;
    }

    if (isGoogleHost(host)) {
      if (
        pathname === '/' ||
        pathname === '/search' ||
        pathname === '/sorry/index' ||
        pathname === '/sorry/' ||
        pathname === '/setprefs' ||
        pathname.startsWith('/search') ||
        pathname.startsWith('/accounts')
      ) {
        return '';
      }
    }

    parsed.hash = '';
    return parsed.toString();
  }

  return '';
}

async function waitUntilSearchReady(page, timeoutMs, headless) {
  const deadline = Date.now() + timeoutMs;
  let prompted = false;
  const selectors = resultSelectors();

  while (Date.now() < deadline) {
    const reason = detectHumanVerification(page.url(), await page.content());
    if (reason) {
      if (headless) {
        return { mode: 'human_verification', reason };
      }
      if (!prompted) {
        prompted = true;
        console.log('检测到人机验证，请在浏览器中手动完成，程序会自动继续。');
      }
      await sleep(1200);
      continue;
    }

    for (const selector of selectors) {
      const count = await page.locator(selector).count();
      if (count > 0) {
        return { mode: 'ready' };
      }
    }
    await sleep(800);
  }

  if (prompted) {
    return { mode: 'error', error: '人工验证后仍未检测到搜索结果，请重试' };
  }
  return { mode: 'error', error: '等待搜索结果超时' };
}

async function collectResults(page, maxResults) {
  const selectors = resultSelectors();
  const results = [];
  const seen = new Set();
  let foundAny = false;

  for (const selector of selectors) {
    const list = page.locator(selector);
    const count = await list.count();
    if (count <= 0) {
      continue;
    }
    foundAny = true;

    for (let i = 0; i < count && results.length < maxResults; i++) {
      const item = list.nth(i);
      const title = String(await item.innerText().catch(() => '')).trim();
      if (!title) {
        continue;
      }

      let link = String(await item.getAttribute('href').catch(() => '') || '').trim();
      if (!link) {
        link = String(await item.locator('xpath=ancestor::a[1]').getAttribute('href').catch(() => '') || '').trim();
      }
      if (!link) {
        continue;
      }

      const cleanURL = normalizeGoogleLink(link);
      if (!cleanURL || seen.has(cleanURL)) {
        continue;
      }

      seen.add(cleanURL);
      results.push({ title, url: cleanURL });
    }
  }

  if (!foundAny) {
    return { error: '未找到结果节点', results: [] };
  }
  return { error: '', results };
}

function sanitizeFileName(input) {
  const source = String(input || '').trim();
  if (!source) {
    return 'untitled';
  }
  const safe = source
    .replace(/[^a-zA-Z0-9\-_ ]+/g, '')
    .replace(/\s+/g, '-')
    .replace(/-+/g, '-')
    .replace(/^[-_]+|[-_]+$/g, '');
  if (!safe) {
    return 'untitled';
  }
  return safe.slice(0, 48);
}

async function main() {
  if (headlessMode !== 'true' && headlessMode !== 'false' && headlessMode !== 'first') {
    writeResult({ status: 'error', error: '不支持的 headless 模式', results: [], snapshotPath: '' });
    return;
  }

  async function runAttempt(useHeadless) {
    let context;
    try {
      context = await chromium.launchPersistentContext(profileDir, {
        headless: useHeadless,
        timeout: timeoutMs,
        ignoreDefaultArgs: ['--enable-automation'],
        args: ['--disable-blink-features=AutomationControlled'],
        ...(channel ? { channel } : {})
      });
      const page = await context.newPage();
      const searchURL = 'https://www.google.com/search?hl=zh-CN&q=' + encodeURIComponent(query);
      await page.goto(searchURL, { waitUntil: 'domcontentloaded', timeout: timeoutMs });

      const ready = await waitUntilSearchReady(page, timeoutMs, useHeadless);
      if (ready.mode === 'human_verification') {
        return { status: 'human_verification', reason: ready.reason, results: [], snapshotPath: '' };
      }
      if (ready.mode === 'error') {
        return { status: 'error', error: ready.error, results: [], snapshotPath: '' };
      }

      const collected = await collectResults(page, maxResults);
      if (collected.error) {
        return { status: 'error', error: collected.error, results: [], snapshotPath: '' };
      }

      let snapshotPath = '';
      if (snapshot) {
        await page.waitForLoadState('load', { timeout: 5000 }).catch(() => {});
        await page.waitForTimeout(900);
        const snapshotDir = path.join(projectRoot, 'snapshots', snapshotStamp);
        fs.mkdirSync(snapshotDir, { recursive: true });
        const filePath = path.join(snapshotDir, 'search-' + sanitizeFileName(query) + '.png');
        await page.screenshot({ path: filePath, fullPage: true, timeout: 15000 });
        snapshotPath = path.resolve(filePath);
      }

      return {
        status: 'ok',
        results: collected.results.map(item => ({ title: item.title, url: item.url })),
        snapshotPath
      };
    } catch (error) {
      return {
        status: 'error',
        error: String(error && error.message ? error.message : error),
        results: [],
        snapshotPath: ''
      };
    } finally {
      if (context) {
        await context.close();
      }
    }
  }

  if (headlessMode === 'first') {
    const first = await runAttempt(true);
    if (first.status === 'ok') {
      writeResult(first);
      process.exitCode = 0;
      return;
    }
    if (first.status === 'human_verification') {
      const second = await runAttempt(false);
      writeResult(second);
      process.exitCode = second.status === 'ok' ? 0 : 1;
      return;
    }
    writeResult(first);
    process.exitCode = 1;
    return;
  }

  const final = await runAttempt(headlessMode === 'true');
  writeResult(final);
  process.exitCode = final.status === 'ok' ? 0 : 1;
}

main();
